// MINDTHREAD data model.
// Local store is SQLite. Because all access goes through the repository layer
// (lib/repositories), switching this datasource to PostgreSQL (Supabase) later
// is a provider change + a re-implementation of the repository, not a rewrite.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" for Vercel's serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime (use Supabase's pooler/IPv4 string on Vercel).
  url       = env("DATABASE_URL")
  // Migrations / `prisma db push` (direct connection).
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  displayName     String    @default("Journal")
  tone            String    @default("warm") // blunt | warm | analytical | close_friend
  model           String? // Gemini model id for AI calls; null = app default
  geminiApiKeyEnc String? // AES-256-GCM ciphertext of the user's Gemini key
  onboardedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  entries      Entry[]
  tasks        Task[]
  chatSessions ChatSession[]
  insights     Insight[]
}

model Entry {
  id            String    @id @default(cuid())
  userId        String
  entryNumber   Int
  rawDump       String
  status        String    @default("draft") // draft | processing | processed | error
  toneUsed      String?
  title         String?
  summary       String?
  aiAnalysis    String?
  reflectiveQuestion String?
  moodScore     Float?
  emotions      String? // JSON string array, e.g. ["anxious","reflective"]
  themes        String? // JSON string array
  feeling       String? // AI: how the writer seems to be feeling
  ideas         String? // JSON string array of ideas worth keeping
  patternName     String? // AI-detected pattern, e.g. "Avoidant Rumination"
  patternWhat     String?
  patternEvidence String? // JSON string array of bullets
  patternAdvice   String?
  patternAttention Boolean @default(false)
  patternTried     Boolean @default(false)
  isConcern     Boolean   @default(false)
  concernStatus String? // unresolved | improving | resolved
  wordCount     Int       @default(0)
  aiError       String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Task {
  id            String    @id @default(cuid())
  userId        String
  title         String
  notes         String? // free-form details / bullet points (plain text)
  status        String    @default("pending") // pending | done | cancelled
  priority      String    @default("normal") // low | normal | high
  source        String    @default("manual") // entry | manual
  sourceEntryId String?
  isConcern     Boolean   @default(false)
  editCount     Int       @default(0) // # of times the task's content was revised
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [sourceEntryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([sourceEntryId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Insight {
  id        String   @id @default(cuid())
  userId    String
  text      String
  category  String?
  basedOn   Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
