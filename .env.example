# Copy to .env and fill in real values.

# Postgres (Supabase). URL-encode special chars in the password (e.g. / -> %2F).
# DATABASE_URL: runtime connection. On Vercel use Supabase's POOLER string (IPv4, port 6543, ?pgbouncer=true).
# DIRECT_URL:   direct connection (port 5432) used for `prisma db push` / migrations.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

AUTH_SECRET="change-me-to-a-long-random-string"
ENCRYPTION_KEY="64-hex-characters-32-bytes-for-aes-256-gcm"
NEXT_PUBLIC_APP_NAME="MINDTHREAD"
